# 复制为 .env 后 docker compose 会自动加载
# cp .env.example .env

# 与 docker-compose.prod.yml 默认一致（root）；生产务必改为强密码并写入 .env
MYSQL_ROOT_PASSWORD=root
MYSQL_PASSWORD=modlink

# 业务配置（jwt、上游密钥等）
MODLINK_CONFIG_FILE=./deploy/docker/config.local.yaml

# 模链云 Nginx 在宿主机上的端口（与其它服务错开；本需求自 8100 起）
HTTP_PORT=8100

IMAGE_TAG=local
